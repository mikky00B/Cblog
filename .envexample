# Frontend
VITE_API_BASE_URL=http://localhost:8000/api

# Backend
APP_NAME=Clevermike Blog API
APP_ENV=development
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:3000
SITE_URL=http://localhost:3000
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/clevermike_blog

# Initial admin user, used by a future seed command.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Media uploads
MEDIA_STORAGE=local
MEDIA_LOCAL_DIR=uploads
MEDIA_PUBLIC_BASE_URL=http://localhost:8000/uploads
MAX_UPLOAD_MB=5
